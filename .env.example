NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=SUA_SUPABASE_PUBLISHABLE_KEY
# Opcional (legado): NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_SUPABASE_ANON_KEY
# Necessaria para cadastro server-side sem confirmacao por email.
SUPABASE_SERVICE_ROLE_KEY=SUA_SUPABASE_SERVICE_ROLE_KEY
SITE_ACCESS_CODE=troque-por-um-codigo-forte
# Opcional (recomendado): segredo dedicado para assinar o cookie de acesso privado.
# Se vazio, o sistema usa SITE_ACCESS_CODE como fallback.
ACCESS_COOKIE_SECRET=troque-por-um-segredo-longo-e-unico
# Chave para permitir overlay do OBS sem login/codigo de acesso
OBS_OVERLAY_KEY=troque-por-uma-chave-forte
